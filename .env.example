# =============================================================================
# Urbano E-commerce – Environment variables
# =============================================================================
# Copy this file to .env and adjust values.
# In production use a secrets manager (AWS Secrets Manager, Vault, etc.)
# and do not commit .env (.env is in .gitignore).
# =============================================================================

# --- PostgreSQL databases (used by docker-compose and services) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Database names (change only if you also change them in compose)
POSTGRES_DB_CATALOG=catalog_db
POSTGRES_DB_USERS=users_prod
POSTGRES_DB_ORDERS=orders_db
POSTGRES_DB_INVENTORY=inventory_db

# --- JWT (auth-service and users-service) ---
# In production generate a secure value: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# --- Internal URLs (Docker only; in production they point to real services) ---
# users-service URL as seen by auth-service inside Docker network
USERS_SERVICE_URL=http://users-service:3000

# inventory-service URL as seen by catalog-service (for stock in product GETs)
INVENTORY_SERVICE_URL=http://inventory-service:3004

# Event bus (RabbitMQ) URL
EVENT_BUS_URL=amqp://event-bus:5672

# --- Ports (optional; services use 3000 internally, mapped in compose) ---
# PORT_CATALOG=3001
# PORT_USERS=3002
# PORT_AUTH=3003
# PORT_INVENTORY=3004
# PORT_ORDERS=3005

# --- CORS (optional) ---
# In production comma-separated list of allowed origins. Empty = allow all (dev).
# CORS_ORIGIN=https://myapp.com,https://admin.myapp.com

# --- Environment (development | production) ---
# Affects TypeORM synchronize and log level
NODE_ENV=development

# --- Datadog (APM + Log correlation) ---
# Optional. If set, traces and logs are sent to Datadog (logs need agent or API).
# DD_API_KEY=<your-datadog-api-key>
# DD_SITE=datadoghq.com
# DD_ENV=development
# Each service sets DD_SERVICE in docker-compose (catalog-service, users-service, etc.)
