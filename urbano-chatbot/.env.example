# =========================================================================
#                    URBANO CHATBOT - VARIABLES DE ENTORNO
# =========================================================================

# Clave API de OpenAI (Obligatorio para la IA y Orquestación del Agente)
# Consigue una en: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# -------------------------------------------------------------------------
# Conexión con los Microservicios de Urbano (Opcional en modo Standalone)
# -------------------------------------------------------------------------
# Si los microservicios de Urbano están levantados localmente (Docker o npm run start:dev),
# el chatbot intentará llamarlos automáticamente.
# Si están caídos o no configurados, el chatbot usará datos simulados (mocks) de alta fidelidad.

CATALOG_SERVICE_URL=http://localhost:3001
INVENTORY_SERVICE_URL=http://localhost:3004
ORDER_SERVICE_URL=http://localhost:3005
